CREATE PROCEDURE MigrateValidData
AS
BEGIN
    BEGIN TRY
        BEGIN TRANSACTION;

        INSERT INTO TargetTable (id, name, salary)
        SELECT id, name, salary
        FROM SourceTable
        WHERE salary IS NOT NULL;

        COMMIT TRANSACTION;
    END TRY

    BEGIN CATCH
        ROLLBACK TRANSACTION;

        PRINT 'Error occurred. Transaction rolled back.';
    END CATCH
END;
